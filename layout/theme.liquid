          src: url("{{ 'AvenirNext-UltraLight.woff2' | file_url }}") format('woff2'),
               url("{{ 'AvenirNext-UltraLight.woff' | file_url }}") format('woff');    
          font-weight: 200;
          font-style: normal;
          font-display: swap;
        }

        @font-face {
          font-family: 'Avenir Next Condensed';
          src: url("{{ 'AvenirNextCondensed-Bold.woff2' | file_url }}") format('woff2'),
               url("{{ 'AvenirNextCondensed-Bold.woff' | file_url }}") format('woff');    
          font-weight: bold;
          font-style: normal;
          font-display: swap;
        }

        :root {
          --font-heading-family: 'Avenir Next';
          --font-body-family: 'Avenir Next';
          --font-avenir-next-csondensed: 'Avenir Next Condensed';
        }
      {% endstyle %}
    {% endif %}

    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      {% comment %} {{ 'component-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
      <noscript>
        <link rel="stylesheet" href="{{ 'component-localization-form.css' | asset_url }}">
      </noscript> {% endcomment %}
      {% render 'async-style', file: 'component-localization-form.css' %}
      <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.predictive_search_enabled -%}
      <link
        rel="stylesheet"
        href="{{ 'component-predictive-search.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
      >
    {%- endif -%}

    <script>
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    
    {% comment %} <script src="{{ 'jquery.min.js' | asset_url }}"></script> {% endcomment %}
    <script>
      // ---- jQuery async loader (prevents "$ is not defined") ----
      (function() {
        var queue = [];
        var realJQueryLoaded = false;

        // Fake jQuery constructor – queue all calls
        function FakeJQuery(selector, context) {
          return new FakeJQuery.fn.init(selector, context);
        }

        FakeJQuery.fn = FakeJQuery.prototype = {
          init: function(selector, context) {
            var args = arguments;
            queue.push(function($) {
              // When replaying, we call the same $() with the original arguments
              $.call(this, selector, context);
            });
            // Return a chainable empty object so code like $('.foo').hide() doesn't break
            return new Proxy({}, {
              get: function(target, prop) {
                if (prop === 'ready') {
                  return function(fn) {
                    queue.push(function($) { $(document).ready(fn); });
                  };
                }
                // Any other method/.css()/.hide() etc. – queue them too
                return function() {
                  var method = prop;
                  var args = arguments;
                  queue.push(function($) {
                    var $el = $(selector, context);
                    if (typeof $el[method] === 'function') {
                      $el[method].apply($el, args);
                    }
                  });
                  return this; // maintain chainability
                };
              }
            });
          },
          ready: function(fn) {
            queue.push(function($) { $(document).ready(fn); });
          }
        };

        // Expose fake objects globally
        window.jQuery = window.$ = FakeJQuery;

        // This function will be called by the real jQuery's onload
        window.__jQueryAsyncInit = function() {
          var real$ = window.jQuery;
          // Process everything that was queued
          for (var i = 0; i < queue.length; i++) {
            queue[i](real$);
          }
          // Now restore the real jQuery globally
          window.jQuery = window.$ = real$;
        };
      })();
    </script>
    <!-- Load real jQuery with defer, replay queue when ready -->
    <script src="{{ 'jquery.min.js' | asset_url }}" defer onload="__jQueryAsyncInit()"></script>
    {% comment %} <script>
      window.jQuery = window.$ = function(handler) {
        if (typeof handler === 'function') {
          document.addEventListener('DOMContentLoaded', handler);
        }
        return window.$;
      };
      window.$.ready = function(handler) {
        document.addEventListener('DOMContentLoaded', handler);
      };
    </script>

    <script src="{{ 'jquery.min.js' | asset_url }}" async></script>

    <script>
      if (typeof jQuery !== 'undefined') {
        window.$ = window.jQuery = jQuery;
      }
    </script> {% endcomment %}

    <script>
