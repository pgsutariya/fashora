{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
{{ 'section-contact-form-with-map.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    --form-background: {{ section.settings.form_background_color }};
    --text-color: {{ section.settings.text_color }};
    --input-background-color: {{ section.settings.input_background_color }};
    --input-color: {{ section.settings.input_color }};
    --input-border-color: {{ section.settings.input_border_color }};
    --button-background-color: {{ section.settings.button_background_color }};
    --button-color: {{ section.settings.button_color }};
    --button-hover-background_color: {{ section.settings.button_hover_background_color }};
    --button-hover-color: {{ section.settings.button_hover_color }};
    --form-background-rgb: {{ section.settings.form_background_color.red }},{{ section.settings.form_background_color.green }},{{ section.settings.form_background_color.blue }};
    --text-color-rgb: {{ section.settings.text_color.red }},{{ section.settings.text_color.green }},{{ section.settings.text_color.blue }};
    --input-background-color-rgb: {{ section.settings.input_background_color.red }},{{ section.settings.input_background_color.green }},{{ section.settings.input_background_color.blue }};
    --input-color-rgb: {{ section.settings.input_color.red }},{{ section.settings.input_color.green }},{{ section.settings.input_color.blue }};
    --input-border-color-rgb: {{ section.settings.input_border_color.red }},{{ section.settings.input_border_color.green }},{{ section.settings.input_border_color.blue }};
    --button-background-color-rgb: {{ section.settings.button_background_color.red }},{{ section.settings.button_background_color.green }},{{ section.settings.button_background_color.blue }};
    --button-color-rgb: {{ section.settings.button_color.red }},{{ section.settings.button_color.green }},{{ section.settings.button_color.blue }};
    --button-hover-background_color-rgb: {{ section.settings.button_hover_background_color.red }},{{ section.settings.button_hover_background_color.green }},{{ section.settings.button_hover_background_color.blue }};
    --button-hover-color-rgb: {{ section.settings.button_hover_color.red }},{{ section.settings.button_hover_color.green }},{{ section.settings.button_hover_color.blue }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="contact-main-page color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {% comment %} <div class="mobile">
      {% if section.settings.sub_title != blank %}
        <div class="sub-title">
          {{ section.settings.sub_title }}
        </div>
      {% endif %}
      {%- if section.settings.heading != blank -%}
        <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.heading }}
        </h2>
      {%- else -%}
        <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
      {%- endif -%}
    </div> {% endcomment %}
    <div class="contact-main">
      <div class="contact center page-width--narrow"{% if section.settings.form_background_color != blank %} style="--background: {{ section.settings.form_background_color }};"{% endif %}>
        <div class="contact-title-wrapper desktop">
          {% if section.settings.sub_title != blank %}
            <div class="sub-title">
              {{ section.settings.sub_title }}
            </div>
          {% endif %}
          {%- if section.settings.heading != blank -%}
            <h2 class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {{ section.settings.heading }}
            </h2>
          {%- else -%}
            <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.textarea != blank -%}
          <div class="desc rte">{{ section.settings.textarea }}</div>
        {%- endif -%}
        {%- liquid
          assign contact_form_class = 'isolate'
          if settings.animations_reveal_on_scroll
            assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
          endif
        -%}
        {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
          {%- if form.posted_successfully? -%}
            <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
              {% render 'icon-success' %}
              {{ 'templates.contact.form.post_success' | t }}
            </h2>
          {%- elsif form.errors -%}
            <div class="form__message">
              <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                {% render 'icon-error' %}
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
            </div>
            <ul class="form-status-list caption-large" role="list">
              <li>
                <a href="#ContactForm-email" class="link">
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </a>
              </li>
            </ul>
          {%- endif -%}
          {% comment %} <div class="contact__fields">
            <div class="field">
              <input
                class="field__input"
                autocomplete="name"
                type="text"
                id="ContactForm-name"
                name="contact[{{ 'templates.contact.form.name' | t }}]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="{{ 'templates.contact.form.name' | t }}"
              >
              <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
            </div>
            <div class="field field--with-error">
              <input
                autocomplete="email"
                type="email"
                id="ContactForm-email"
                class="field__input"
                name="contact[email]"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error"
                {% endif %}
                placeholder="{{ 'templates.contact.form.email' | t }}"
              >
              <label class="field__label" for="ContactForm-email">
                {{- 'templates.contact.form.email' | t }}
                <span aria-hidden="true">*</span></label
              >
              {%- if form.errors contains 'email' -%}
                <small class="contact__field-error" id="ContactForm-email-error">
                  <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                  <span class="form__message">
                    {%- render 'icon-error' -%}
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </span>
                </small>
              {%- endif -%}
            </div>
          </div>
          <div class="field">
            <input
              type="tel"
              id="ContactForm-phone"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.phone' | t }}]"
              pattern="[0-9\-]*"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              placeholder="{{ 'templates.contact.form.placeholder_phone' | t }}"
            >
            <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
          </div> {% endcomment %}
          <div class="field">
            <input
              class="field__input"
              autocomplete="name"
              type="text"
              id="ContactForm-name"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'templates.contact.form.placeholder_name' | t }}"
            >
            <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
          </div>
          <div class="field field--with-error">
            <input
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              class="field__input"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{ 'templates.contact.form.placeholder_email' | t }}"
            >
            <label class="field__label" for="ContactForm-email">
              {{- 'templates.contact.form.email' | t }}
              <span aria-hidden="true">*</span></label
            >
            {%- if form.errors contains 'email' -%}
              <small class="contact__field-error" id="ContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message">
                  {%- render 'icon-error' -%}
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
          <div class="field">
            <input
              type="text"
              id="ContactForm-subject"
              class="field__input"
              autocomplete="tel"
              name="contact[{{ 'templates.contact.form.subject' | t }}]"
              value="{% if form.subject %}{{ form.subject }}{% endif %}"
              placeholder="{{ 'templates.contact.form.placeholder_subject' | t }}"
            >
            <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.subject' | t }}</label>
          </div>
          <div class="field">
            <textarea
              rows="10"
              id="ContactForm-body"
              class="text-area field__input"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.placeholder_comment' | t }}"
            >
              {{- form.body -}}
            </textarea>
            <label class="form__label field__label" for="ContactForm-body">
              {{- 'templates.contact.form.comment' | t -}}
            </label>
          </div>
          <div class="contact__button">
            <button
              type="submit"
              class="{% if section.settings.button_style == 'link' %}link underlined-link{% elsif section.settings.button_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
            >
              {{ 'templates.contact.form.send' | t }}
            </button>
          </div>
        {%- endform -%}
      </div>
      <div class="contact-info contact-img contact-map">
        <div class="contact-service">
          {%- if section.settings.info != blank -%}
            <div class="contact-service-info rte">{{- section.settings.info -}}</div>
          {%- endif -%}
        </div>
        {%- if section.blocks.size > 0 -%}
          <div class="contact-image-text">
            <ul class="image-text-list image-text-grid grid grid--2-col-tablet-down grid--2-col-tablet grid--2-col-desktop" role="list">
              {%- for block in section.blocks -%}
                {%- if block.settings.image != blank or block.settings.text != blank %}
                  <li
                    class="image-text-list__item image-text-grid__item grid__item center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {{ block.shopify_attributes }}
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ forloop.index }};"
                    {% endif %}
                  >
                    <div class="image-text">
                      {%- if block.settings.image != blank %}
                        <div class="image-text--image">
                          <div
                            class="media media--transparent media--adapt"
                            style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                          >
                            {% capture sizes %}
                              (min-width: {{ settings.page_width }}px) 100vw,
                              (min-width: 990px) 100vw,
                              (min-width: 750px) 100vw,
                              100vw
                            {% endcapture %}
                            {{
                              block.settings.image
                              | image_url: width: 60
                              | image_tag:
                                width: block.settings.image.width,
                                height: block.settings.image.height,
                                widths: '60, 120, 180, 240, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                                sizes: sizes,
                                class: 'image-text__image',
                                alt: block.settings.image.alt,
                                fetchpriority: 'auto'
                            }}
                          </div>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.text != blank %}
                      <div class="image-text--text rte">
                        {{- block.settings.text -}}
                      </div>
                      {%- endif -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        <div class="contact-img-inner contact-map-inner">
          {%- if section.settings.iframe_code != blank -%}
            <div class="map" style="width: 100%;">
              <iframe
                src="{{ section.settings.iframe_code }}"
                width="100%"
                height="348"
                frameborder="0"
                style="border:0;"
              ></iframe>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.contact-form-with-map.name",
  "tag": "section",
  "class": "section contact-page-with-map",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "liquid",
      "id": "iframe_code",
      "default": "https://www.google.com/maps/embed?pb=!1m16!1m12!1m3!1d2965.0824050173574!2d-93.63905729999999!3d41.998507000000004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!2m1!1sWebFilings%2C+University+Boulevard%2C+Ames%2C+IA!5e0!3m2!1sen!2sus!4v1390839289319",
      "label": "t:sections.contact-form-with-map.settings.iframe_code.label"
    },
    {
      "type": "text",
      "id": "sub_title",
      "label": "t:sections.contact-form-with-map.settings.sub_title.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.contact-form-with-map.settings.title.default",
      "label": "t:sections.contact-form-with-map.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "textarea",
      "label": "t:sections.contact-form-with-map.settings.textarea.label",
      "default": "t:sections.contact-form-with-map.settings.textarea.default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "form_background_color",
      "label": "t:sections.contact-form-with-map.settings.form_background_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#ECECEC"
    },
    {
      "type": "color",
      "id": "input_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "t:sections.contact-form-with-map.settings.input_border_color.label",
      "default": "#B3B3B3"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#BFBFBF"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "t:sections.contact-form-with-map.settings.button_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "t:sections.contact-form-with-map.settings.text_color.label",
      "default": "#BFBFBF"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.multirow.settings.button_style.label",
      "options": [
        {
          "value": "link",
          "label": "t:sections.multirow.settings.button_style.options__1.label"
        },
        {
          "value": "outline",
          "label": "t:sections.multirow.settings.button_style.options__2.label"
        },
        {
          "value": "solid",
          "label": "t:sections.multirow.settings.button_style.options__3.label"
        }
      ],
      "default": "solid"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "header",
      "content": "t:sections.contact-form-with-map.settings.header_service.content"
    },
    {
      "type": "richtext",
      "id": "info",
      "label": "t:sections.contact-form-with-map.settings.info.label",
      "default": "t:sections.contact-form-with-map.settings.info.default"
    }
  ],
  "blocks": [
    {
      "type": "image-text",
      "name": "t:sections.contact-form-with-map.blocks.image-text.name",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.contact-form-with-map.blocks.image-text.settings.image.label",
          "info": "t:sections.contact-form-with-map.blocks.image-text.settings.image.info"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.contact-form-with-map.blocks.image-text.settings.text.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form-with-map.presets.name"
    }
  ]
}
{% endschema %}