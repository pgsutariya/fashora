{% render 'async-style', file: 'section-shopable-videos.css' %}
{% render 'async-style', file: 'video-section.css' %}
{% render 'async-style', file: 'component-deferred-media.css' %}
{% render 'async-style', file: 'component-slider.css' %}

{% render 'swiper-assets' %}

<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>


{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  {% if section.settings.gap_items == true %}
    .instagrma-{{ section.id }} .shopable-videos .grid {
      column-gap: 0;
      row-gap: 0;
    }
  {% endif %}

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and section.blocks.size > columns_desktop_int
    assign show_desktop_slider = true
  endif

-%}

<div class="isolate gradient color-{{ section.settings.color_scheme }} shopable-videos-{{ section.id }}">
  <div class="shopable-videos section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}">
    <div class="title-wrapper title-wrapper--no-top-margin {% if section.settings.full_width == false %} page-width{% endif %} {% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.heading != blank -%}
        <h2
          class="main-title title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="text-align: {{ section.settings.heading_alignment }};"
        >
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      {% if section.settings.sub_title != blank %}
        <div class="sub-title" style="text-align: {{ section.settings.heading_alignment }};">
          {{ section.settings.sub_title }}
        </div>
      {% endif %}
    </div>

    <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width {% else %} page-width {% endif %} {% if show_desktop_slider == false and section.settings.full_width == false %}page-width page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
      {%- liquid
        assign highest_ratio = 0
        for block in section.blocks
          if block.settings.image.aspect_ratio > highest_ratio
            assign highest_ratio = block.settings.image.aspect_ratio
          endif
        endfor
      -%}
      <ul
        id="Slider-{{ section.id }}"
        class="grid product-grid contains-card{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down {% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        role="list"
        aria-label="{{ 'sections.featured_collection.slider' | t }}"
      >
        {%- for block in section.blocks -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- case block.type -%}
              {%- when 'video' -%}
                 {%- liquid
                     assign video_alt = block.settings.file_video_url.alt | default: block.settings.description
                    assign alt = 'sections.video.load_video' | t: description: video_alt | escape
                    assign video_id = block.settings.file_video_url.id | default: block.settings.video_url.id
                   assign loop = '&loop=1&playlist=' | append: video_id
                  -%}
              
                <div class="shopable-video-inner {% if block.settings.shop_product != blank %} shop-product-style{% endif %}{% if section.settings.enable_story_style == true %} story-style{% endif %}">
                  <div data-slide-index="{{ forloop.index | minus:1 }}" class="video-slider video-slider-{{ section.id }} video{% if block.settings.file_video_url == null %} placeholder{% endif %}">
                    <div class="video-section isolate">
                      <div
                        class="video-section__media media deferred-media no-js-hidden gradient global-media-settings"
                        data-media-id="{{ video_id }}"
                        {% if section.settings.enable_story_style == true %}
                           style="--ratio-percent: 100%;"
                        {% else %}
                           style="--ratio-percent: 150%;"
                        {% endif %}
                      >

                         {%- if block.settings.file_video_url == null and block.settings.video_url != null -%}
                           {%- if block.settings.video_url.type == 'youtube' -%}
                            <iframe
                              src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1&mute=1&controls=0{{ loop }}"
                              class="js-youtube shop-video"
                              allow="autoplay; encrypted-media"
                              allowfullscreen
                              muted
                              title="{{ section.settings.description | escape }}"
                            ></iframe>
                          {%- else -%}
                            <iframe
                              src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&mute=1&controls=0{{ loop }}"
                              class="js-vimeo shop-video"
                              allow="autoplay; encrypted-media"
                              allowfullscreen
                              muted
                              title="{{ block.settings.description | escape }}"
                            ></iframe>
                          {%- endif -%}
                        {% else %}
                          {%- if block.settings.file_video_url != blank -%}
                            {%- liquid
                              assign video_id = block.settings.file_video_url.id
                            -%}
                              {%- if block.settings.file_video_url != blank -%}
                                <video class="shop-video" width="100%" height="auto" autoplay muted loop playsInline>
                                  <source src="{{ block.settings.file_video_url}}" type="video/mp4">
                                </video>
                              {%- endif -%}
                          {% else %}
                            <div class="video-section__placeholder">
                              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                            </div>
                          {% endif %}
                        {% endif %}
                      </div>
                    </div>
                </div>

                {% if block.settings.shop_product != blank and section.settings.enable_story_style == false %}
                  {% assign shoppro = block.settings.shop_product %}
                  <div class="shopable-product">
                    <div class="product-item product__item-js style-as-standard">
                      <div class="product-item__wrapper hover_zoom">
                        <div class="product-item__inner hover-effect">
                          <a
                            href="{{ block.settings.shop_product.url }}"
                            class="product__media product-item__media--ratio"
                            style="--aspect-ratio: 3/4;"
                          >
                            <img
                              src="{{ block.settings.shop_product.featured_media | image_url }}"
                              alt="{{ block.settings.shop_product.featured_media.alt }}"
                              width="{{ block.settings.shop_product.featured_media.width }}"
                              height="{{ block.settings.shop_product.featured_media.height }}"
                              loading="lazy"
                              class="product-image first-image"
                            >
                          </a>
                        </div>

                        <div class="product-item__information">
                          <a
                            aria-label="{{ block.settings.shop_product.title }}"
                            class="product-item__name heading-style"
                            href="{{ block.settings.shop_product.url }}"
                          >
                            {{- block.settings.shop_product.title -}}
                          </a>

                          {% render 'price', product: shoppro, price_class: '', show_compare_at_price: true %}

                          <div class="shopable-add-to-cart">
                            {% if shoppro.variants[0].available %}
                              <product-form data-section-id="{{ section.id }}">
                                {% assign product_form_id = shoppro.id %}
                                {%- form 'product',
                                  shoppro,
                                  id: product_form_id,
                                  class: 'form',
                                  novalidate: 'novalidate',
                                  data-type: 'add-to-cart-form'
                                -%}
                                  <input
                                    type="hidden"
                                    name="id"
                                    value="{{ shoppro.selected_or_first_available_variant.id }}"
                                    class="product-variant-id"
                                    {% if shoppro.selected_or_first_available_variant.available == false %}
                                      disabled
                                    {% endif %}
                                  >
                                  <button
                                    id="{{ product_form_id }}-submit"
                                    type="submit"
                                    name="add"
                                    class="quick-add__submit button button--full-width button--primary{% if horizontal_quick_add %} card--horizontal__quick-add{% endif %}"
                                    aria-haspopup="dialog"
                                    aria-labelledby="{{ product_form_id }}-submit title-{{ section_id }}-{{ shoppro.id }}"
                                    aria-live="polite"
                                    data-sold-out-message="true"
                                    {% if shoppro.selected_or_first_available_variant.available == false %}
                                      disabled
                                    {% endif %}
                                  >
                                    <span>
                                      
                                      {%- if shoppro.selected_or_first_available_variant.available -%}
                                        {{ 'products.product.add_to_cart' | t }}
                                      {%- else -%}
                                        {{ 'products.product.sold_out' | t }}
                                      {%- endif -%}
                                    </span>
                                    <span class="sold-out-message hidden">
                                      {{ 'products.product.sold_out' | t }}
                                    </span>
                                    {%- render 'loading-spinner' -%}
                                  </button>
                                {%- endform -%}
                              </product-form>
                            {% else %}
                              soldout
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endcase -%}

            
            
          </li>
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          {% comment %}
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ products_to_display }}</span>
            </div>
          {% endcomment %}
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
</div>

<!-- main-video-swiper -->
<div class="main-video-swiper main-video-swiper-{{ section.id }} shopable-videos">
   <div class="swiper-container popup-video-slider">
        <div
          class="swiper-wrapper product-grid contains-card{% if settings.card_style == 'standard' %} contains-card--standard{% endif %}"
          role="list"
          aria-label="{{ 'sections.featured_collection.slider' | t }}"
