      <div class="swiper-button swiper-button-prev"> {% render 'icon-caret' %} </div>
      <div class="swiper-button swiper-button-next"> {% render 'icon-caret' %} </div>
  </div>
            
   <a class="closevideo" style="cursor: pointer;">
    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" fill="none" viewBox="0 0 18 17">
      <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
    </svg>
  </a>
</div>

<script defer>
  $(function() {
    window.SpeedoFashoraTheme.waitForSwiper(function() {
      $('.video-slider-{{ section.id }}').on('click', function() {
        var $fixslide = $(this).attr("data-slide-index");
        $(".main-video-swiper-{{ section.id }}").show();
        requestAnimationFrame(function() {
          var mySwiper = new Swiper(".main-video-swiper-{{ section.id }} .popup-video-slider", {
            spaceBetween: 1,
            slidesPerView: 3,
            centeredSlides: true,
            roundLengths: true,
            loop: true,
            loopAdditionalSlides: 30,
            navigation: {
              nextEl: ".swiper-button-next",
              prevEl: ".swiper-button-prev"
            },
            breakpoints: {
              990: {
                  slidesPerView: 3
              },
              320: {
                  slidesPerView: 1
              }
            }
          });
          mySwiper.slideTo($fixslide); // Correctly calls slideNext to go to the next slide
        });
      });
    });

    $('.main-video-swiper-{{ section.id }} .closevideo').click(function(){ $('.main-video-swiper-{{ section.id }}').hide(); }); 
    $('.main-video-swiper-{{ section.id }} .shopable-add-to-cart .quick-add__submit').click(function(){ $('.main-video-swiper-{{ section.id }}').hide(); }); 
  });
</script>


{% schema %}
{
  "name": "t:sections.shopable-videos.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
  {
    "type": "text",
    "id": "heading",
    "label": "t:sections.featured-blog.settings.heading.label"
  },
  {
    "type": "text",
    "id": "sub_title",
    "label": "t:sections.custom_instagram_img.settings.sub_title.label"
  },
  {
    "type": "select",
    "id": "heading_size",
    "options": [
      {
        "value": "h2",
        "label": "t:sections.all.heading_size.options__1.label"
      },
      {
        "value": "h1",
        "label": "t:sections.all.heading_size.options__2.label"
      },
      {
        "value": "h0",
        "label": "t:sections.all.heading_size.options__3.label"
      }
    ],
    "default": "h1",
    "label": "t:sections.all.heading_size.label"
  },
  {
    "type": "select",
    "id": "heading_alignment",
    "label": "t:sections.collapsible_content.settings.heading_alignment.label",
    "options": [
      {
        "value": "left",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
      },
      {
        "value": "center",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
      },
      {
        "value": "right",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__3.label"
      }
    ],
    "default": "center"
  },
  {
    "type": "select",
    "id": "image_ratio",
    "options": [
      {
        "value": "adapt",
        "label": "t:sections.collection-list.settings.image_ratio.options__1.label"
      },
      {
        "value": "portrait",
        "label": "t:sections.collection-list.settings.image_ratio.options__2.label"
      },
      {
        "value": "square",
        "label": "t:sections.collection-list.settings.image_ratio.options__3.label"
      }
    ],
    "default": "square",
    "label": "t:sections.collection-list.settings.image_ratio.label",
    "info": "t:sections.collection-list.settings.image_ratio.info"
  },
  {
    "type": "checkbox",
    "id": "full_width",
    "label": "t:sections.custom_instagram_img.settings.full_width.label",
    "default": false
  },
  {
    "type": "checkbox",
    "id": "gap_items",
    "label": "t:sections.custom_instagram_img.settings.gap_items.label",
    "default": false
  },
  {
    "type": "color_scheme",
     "id": "color_scheme",
     "label": "t:sections.all.colors.label",
     "default": "background-1"
  },
  {
    "type": "range",
    "id": "columns_desktop",
    "min": 1,
    "max": 8,
    "step": 1,
    "default": 5,
    "label": "t:sections.collection-list.settings.columns_desktop.label"
  },
  {
    "type": "checkbox",
    "id": "enable_story_style",
    "label": "t:sections.shopable-videos.settings.enable_story_style.label",
    "default": false
  },
  {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_top",
    "default": 50
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_bottom",
    "default": 50
  },
  {
    "type": "checkbox",
    "id": "enable_desktop_slider",
    "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
    "default": false
  },
  {
    "type": "header",
    "content": "t:sections.multicolumn.settings.header_mobile.content"
  },
  {
    "type": "select",
    "id": "columns_mobile",
    "options": [
      {
        "value": "1",
        "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
      },
      {
