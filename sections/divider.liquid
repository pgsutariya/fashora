{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    margin-top: {{ section.settings.margin_top | times: 0.50 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.60 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="divider isolate{% unless section.settings.full_width %} page-width{% endunless %}">
  <div class="divider-inner color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" style="border-bottom:1px solid {{ section.settings.border_color}}">
  </div>
</div>

{% schema %}
{
  "name": "t:sections.divider.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "border_color",
      "default": "#ededed",
      "label": "t:sections.divider.settings.border_color.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.rich-text.settings.full_width.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.divider.settings.margin_top.label",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.divider.settings.margin_bottom.label",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.divider.presets.name"
    }
  ]
}
{% endschema %}