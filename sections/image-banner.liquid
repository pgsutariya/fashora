            },
            {
              "value": "caption-with-letter-spacing",
              "label": "t:sections.image-banner.blocks.caption.settings.text_style.options__2.label"
            }
          ],
          "default": "caption-with-letter-spacing",
          "label": "t:sections.image-banner.blocks.caption.settings.text_style.label"
        },
        {
          "type": "select",
