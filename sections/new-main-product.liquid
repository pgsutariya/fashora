                  	<path d="M 57.169 64.41 c -4.801 0 -8.707 -3.906 -8.707 -8.707 s 3.906 -8.707 8.707 -8.707 s 8.707 3.906 8.707 8.707 S 61.97 64.41 57.169 64.41 z M 57.169 50.996 c -2.596 0 -4.707 2.111 -4.707 4.707 s 2.111 4.707 4.707 4.707 s 4.707 -2.111 4.707 -4.707 S 59.765 50.996 57.169 50.996 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(255,255,255); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"></path>
