                      <div class="discount-coupon-code">
                        <a href="#discount-coupon-{{ block.id }}-{{ section.id }}" rel="modal:open">
                          <div class="discount-coupon-code-left">
                            {% if block.settings.offer_title != blank %}
                              <div class="discount-coupon-code-left-title">
                                {{ block.settings.offer_title }}
                              </div>
                            {% endif %}
                          </div>
                        </a>
                        <div id="discount-coupon-{{ block.id }}-{{ section.id }}" class="discount-coupon-code-right modal">
                           <span class="dis-tooltip" id="myTooltip-{{ block.id }}-{{ section.id }}" style="display:none;"></span>
                          <h3 class="popup-title">{{ block.settings.popup_title }}</h3>
                          {% if block.settings.popup_text_deatil != blank %}
                            <div class="rich-text-detail">{{ block.settings.popup_text_deatil }}</div>
                          {% endif %}
                           <div class="dis-popup-text">
                              {% if block.settings.popup_text != blank %}
                                <div class="rich-text">{{ block.settings.popup_text }}</div>
                              {% endif %}
                              <div class="discount-coupon-code-copy coupon-code-copy--{{ block.id }}">
                                {% if block.settings.copy_text != blank %}
                                  <p class="discount-coupon-code-copy-title">{{ block.settings.copy_text }}</p>
                                {% endif %}
                                {% if block.settings.coupon_code != blank %}
                                  <input type="text" value="{{ block.settings.coupon_code }}" id="myInput-{{ block.id }}-{{ section.id }}" style="display:none;">
                                  <p class="discount-coupon-code-copy-coupon">{{ block.settings.coupon_code }}</p>
                                {% endif %}
                             </div>
                          </div>
                        </div>
                      </div>
                     </div>
               
                    <script defer>
                     /*function myFunction() {
                        var copyText = document.getElementById("myInput-{{ block.id }}-{{ section.id }}");
                        copyText.select();
                        copyText.setSelectionRange(0, 99999);
                        navigator.clipboard.writeText(copyText.value);
                        console.log(copyText);
                        var tooltip = document.getElementById("myTooltip-{{ block.id }}-{{ section.id }}");
                        tooltip.innerHTML = "Copied";
                        tooltip.style.display = "block";
                      }*/
                      $(document).ready(function() {
                        $(".discount-coupon-code-block-inner").each(function(){
                            $(this).find(".coupon-code-copy--{{ block.id }}").click(function() {
                                var copyText = $("#myInput-{{ block.id }}-{{ section.id }}")[0]; // Access the DOM element
                                copyText.select();
                                copyText.setSelectionRange(0, 99999);
                                navigator.clipboard.writeText(copyText.value);
                                console.log(copyText);
                                
                                var tooltip = $("#myTooltip-{{ block.id }}-{{ section.id }}");
                                tooltip.html("Copied");
                                tooltip.show();
