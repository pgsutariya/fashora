{% render 'async-style', file: 'section-custom-instagram.css' %}
{% render 'async-style', file: 'video-section.css' %}
{% render 'async-style', file: 'component-deferred-media.css' %}
{% render 'async-style', file: 'component-slider.css' %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  {% if section.settings.gap_items == true %}
    .instagrma-{{ section.id }} .custom_instagram .grid {
      --grid-desktop-horizontal-spacing: 0px;
      --grid-desktop-vertical-spacing: 0px;
      --grid-mobile-horizontal-spacing: 0px;
      --grid-mobile-vertical-spacing: 0px;
    }
    .instagrma-{{ section.id }} .custom_instagram .media,
    .instagrma-{{ section.id }} .custom_instagram .image_wrapper .instagram__link:after{
      border-radius: 0;
    }
  {% endif %}

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and section.blocks.size > columns_desktop_int
    assign show_desktop_slider = true
  endif
-%}


<div class="isolate gradient color-{{ section.settings.color_scheme }} instagrma-{{ section.id }}">
  <div class="custom_instagram section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}">
    <div class="title-wrapper title-wrapper--no-top-margin {% if section.settings.full_width == false %} page-width{% endif %} {% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.heading != blank -%}
        <h2
          class="main-title title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="text-align: {{ section.settings.heading_alignment }};"
        >
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      {% if section.settings.sub_title != blank %}
        <div class="sub-title" style="text-align: {{ section.settings.heading_alignment }};">
          {{ section.settings.sub_title }}
        </div>
      {% endif %}
    </div>

    <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width {% else %} page-width-desktop {% endif %} {% if show_desktop_slider == false and section.settings.full_width == false %}page-width page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
      {%- liquid
        assign highest_ratio = 0
        for block in section.blocks
          if block.settings.image.aspect_ratio > highest_ratio
            assign highest_ratio = block.settings.image.aspect_ratio
          endif
        endfor
      -%}
      <ul
        id="Slider-{{ section.id }}"
        class="grid product-grid contains-card{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down {% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        role="list"
        aria-label="{{ 'sections.featured_collection.slider' | t }}"
      >
        {%- for block in section.blocks -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
           {%- case block.type -%}
             {%- when 'image' -%}
                <div class="content-container {{ section.settings.content_alignment }}">
                {%- if block.settings.image != blank -%}
                  {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                    {% assign spaced_image = true %}
                  {% endif %}
                  <div class="image_wrapper">
                    <div
                      class="media media--{{ section.settings.image_ratio }}"
                      {% if section.settings.image_ratio == 'adapt' %}
                        style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                      {% endif %}
                    >
                      <img
                        class="custom-icon-card__image"
                        srcset="
                          {%- if block.settings.image.width >= 275 -%}{{ block.settings.image | image_url: width: 275 }} 275w,{%- endif -%}
                          {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
                          {%- if block.settings.image.width >= 710 -%}{{ block.settings.image | image_url: width: 710 }} 710w,{%- endif -%}
                          {%- if block.settings.image.width >= 1420 -%}{{ block.settings.image | image_url: width: 1420 }} 1420w,{%- endif -%}
                          {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
                        "
                        src="{{ block.settings.image | image_url: width: 550 }}"
                        sizes="
                          (min-width: 990px) {% if section.blocks.size <= 2 %}710px{% else %}550px{% endif %},
                          (min-width: 750px) {% if section.blocks.size == 1 %}710px{% else %}550px{% endif %},
                          calc(100vw - 30px)
                        "
                        alt="{{ block.settings.image.alt }}"
                        height="{{ block.settings.image.height }}"
                        width="{{ block.settings.image.width }}"
                        loading="lazy"
                      >
                    </div>
                    
                    {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}" class="instagram__link">
                       {% render 'icon-instagram-hover' %}
                      </a>
                    {% endif %}
                  </div>
                {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
              </div>

            {%- when 'video' -%}
               {%- if block.settings.file_video_url != blank -%}
                  {%- liquid
                      assign video_id = block.settings.file_video_url.id
                 -%}
                  <div class="instagram-video media{% if block.settings.file_video_url == null %} placeholder{% endif %}">
                    <div class="video-section isolate">
                      <div
                        class="video-section__media deferred-media no-js-hidden gradient global-media-settings"
                        data-media-id="{{ video_id }}"
                      >
                         {%- if block.settings.file_video_url != blank -%}
                            <video width="100%" height="auto" autoplay muted loop playsInline>
                              <source src="{{ block.settings.file_video_url}}" type="video/mp4">
                            </video>
                         {%- endif -%}
                      </div>
                    </div>
                     {% if block.settings.link != blank %}
                      <a href="{{ block.settings.link }}" class="instagram__link">
                        {% render 'icon-instagram-hover' %}
                      </a>
                    {% endif %}
                  </div>
                {% else %}
                   <div class="video-section__placeholder">
                     {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                   </div>
                {% endif %}
            {%- endcase -%}
          </li>
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          {% comment %}
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ products_to_display }}</span>
            </div>
          {% endcomment %}
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.custom_instagram_img.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
  {
    "type": "text",
    "id": "heading",
    "default": "@FashiPassion",
    "label": "t:sections.featured-blog.settings.heading.label"
  },
  {
    "type": "text",
    "id": "sub_title",
    "default": "#follow on social media",
    "label": "t:sections.custom_instagram_img.settings.sub_title.label"
  },
  {
    "type": "select",
    "id": "heading_size",
    "options": [
      {
        "value": "h2",
        "label": "t:sections.all.heading_size.options__1.label"
      },
      {
        "value": "h1",
        "label": "t:sections.all.heading_size.options__2.label"
      },
      {
        "value": "h0",
        "label": "t:sections.all.heading_size.options__3.label"
      }
    ],
    "default": "h1",
    "label": "t:sections.all.heading_size.label"
  },
  {
    "type": "select",
    "id": "heading_alignment",
    "label": "t:sections.collapsible_content.settings.heading_alignment.label",
    "options": [
      {
        "value": "left",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
      },
      {
        "value": "center",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
      },
      {
        "value": "right",
        "label": "t:sections.collapsible_content.settings.heading_alignment.options__3.label"
      }
    ],
    "default": "center"
  },
  {
    "type": "select",
    "id": "image_ratio",
    "options": [
      {
        "value": "adapt",
        "label": "t:sections.collection-list.settings.image_ratio.options__1.label"
      },
      {
        "value": "portrait",
        "label": "t:sections.collection-list.settings.image_ratio.options__2.label"
      },
      {
        "value": "square",
        "label": "t:sections.collection-list.settings.image_ratio.options__3.label"
      }
    ],
    "default": "square",
    "label": "t:sections.collection-list.settings.image_ratio.label",
    "info": "t:sections.collection-list.settings.image_ratio.info"
  },
  {
    "type": "checkbox",
    "id": "full_width",
    "label": "t:sections.custom_instagram_img.settings.full_width.label",
    "default": false
  },
  {
    "type": "checkbox",
    "id": "gap_items",
    "label": "t:sections.custom_instagram_img.settings.gap_items.label",
    "default": false
  },
  {
    "type": "color_scheme",
     "id": "color_scheme",
     "label": "t:sections.all.colors.label",
     "default": "background-1"
  },
  {
    "type": "range",
    "id": "columns_desktop",
    "min": 1,
    "max": 8,
    "step": 1,
    "default": 5,
    "label": "t:sections.collection-list.settings.columns_desktop.label"
  },
  {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_top",
    "default": 50
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 100,
    "step": 2,
    "unit": "px",
    "label": "t:sections.all.padding.padding_bottom",
    "default": 50
  },
  {
    "type": "checkbox",
    "id": "enable_desktop_slider",
    "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
    "default": false
  },
  {
    "type": "header",
    "content": "t:sections.multicolumn.settings.header_mobile.content"
  },
  {
    "type": "select",
    "id": "columns_mobile",
    "options": [
      {
        "value": "1",
        "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
      },
      {
        "value": "2",
        "label": "t:sections.multicolumn.settings.columns_mobile.options__2.label"
      }
    ],
    "default": "2",
    "label": "t:sections.multicolumn.settings.columns_mobile.label"
  },
  {
    "type": "checkbox",
    "id": "swipe_on_mobile",
    "default": false,
    "label": "t:sections.multicolumn.settings.swipe_on_mobile.label"
  }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.custom_instagram_img.blocks.image.name",
      "settings": [
        {
          "type":"image_picker",
          "id":"image",
          "label": "t:sections.custom_instagram_img.blocks.image.settings.image.label"
        },
        {
          "type":"url",
          "id":"link",
          "label": "t:sections.custom_instagram_img.blocks.image.settings.link.label"
        }
      ]
    }, 
    {
      "type":"video",
      "name": "Video",
      "settings": [
        {
          "type": "header",
          "content": "File video"
        },
        {
          "type": "url",
          "id": "file_video_url",
          "label": "File video Url",
          "info": "Go to admin>content>files option add/upload the video then copy the link and paste it here."
        },
        {
          "type":"url",
          "id":"link",
          "label": "Video link"
        }
      ]
    }
  ],
   "presets": [
    {
      "name": "t:sections.custom_instagram_img.presets.name",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

