{% render 'async-style', file: 'section-categories-slider.css' %}
{% render 'async-style', file: 'section-multicolumn.css' %}
{% render 'async-style', file: 'component-slider.css' %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .categorie-slider.background-primary .section-{{ section.id }}-padding .multicolumn-card{
    background: {{ section.settings.column_bkg_color }};
  }
  .categorie-slider .section-{{ section.id }}-padding .multicolumn-card__image-wrapper{
    background: {{ section.settings.image_bkg_color }};
    border: 2px solid {{ section.settings.image_border_color }};
  }

  .categorie-slider .section-{{ section.id }}-padding .multicolumn-card__image-wrapper,
  .categorie-slider .section-{{ section.id }}-padding .multicolumn-card__image-wrapper .media {
    border-radius: {{ section.settings.image_border_radius }}%;
  }

  {% if section.settings.image_width == 'custom' %}
     .categorie-slider .section-{{ section.id }}-padding .multicolumn-card__image-wrapper--custom-width { width: {{ section.settings.custom_width }}px;}
  {% endif %}
  {% if section.settings.enable_slider != true %}
    .categorie-slider .categorie-slider-inner .grid {
       justify-content: center;  
    }
  {% endif %}

 @media screen and (min-width: 750px) {
    #section-{{ section.id }}.categorie-slider.section-view-mobile {
       display: none !important;
    }
  }
  @media screen and (max-width: 749px) {
    #section-{{ section.id }}.categorie-slider.section-view-desktop {
       display: none !important;
    }
  }
{%- endstyle -%}

{% if section.settings.enable_slider == true %}
  {% render 'swiper-assets' %}
{% endif %}

<div id="section-{{ section.id }}" class="categorie-slider section-view-{{ section.settings.section_view }}"" {% if section.settings.class != blank %} {{ section.settings.class }}{% endif %} color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %}">
  <div
    class="categorie-slider-inner{% if section.settings.layout == 'grid' %} page-width{% else %} full-width{% endif %} section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin" style="justify-content: {{ section.settings.heading_alignment }};">
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}
    <div class="{% if section.settings.enable_slider == true %}cate_slider swiper-container{% endif %}" id="Slider-{{ section.id }}">
      <ul
        class="{% if section.settings.enable_slider == true %} swiper-wrapper{% else %}contains-content-container grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop{% endif %} list-unstyled"
        role="list"
      >
        {%- liquid
          assign highest_ratio = 0
          for block in section.blocks
            if block.settings.image.aspect_ratio > highest_ratio
              assign highest_ratio = block.settings.image.aspect_ratio
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.image == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- assign empty_column = ' multicolumn-list__item--empty' -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="{% if section.settings.enable_slider == true %}swiper-slide{% else %}multicolumn-list__item grid__item{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}{{ empty_column }}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="multicolumn-card content-container">
              {%- if block.settings.image != blank -%}
                {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                  {% assign spaced_image = true %}
                {% endif %}
                 <a
                    class="link animate-arrow {% if block.settings.link == collection.url %}active{% endif %}"
                    {% if block.settings.link == blank %}
                     role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width{% if section.settings.image_width != 'full' or spaced_image %} multicolumn-card-spacing{% endif %}">
                <div
                    class="media media--transparent media--{{ section.settings.image_ratio }}"
                    {% if section.settings.image_ratio == 'adapt' %}
                      style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                    {% endif %}
                  >
                    {%- liquid
                      assign number_of_columns = section.settings.columns_desktop
                      assign number_of_columns_mobile = section.settings.columns_mobile
                      assign grid_space_desktop = number_of_columns | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_tablet = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                      assign grid_space_mobile = number_of_columns_mobile | minus: 1 | times: settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                      if section.settings.image_width == 'half'
                        assign image_width = 0.5
                      elsif section.settings.image_width == 'third'
                        assign image_width = 0.33
                      else
                        assign image_width = 1
                      endif
                    -%}
                    {% capture sizes %}
                      (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) * {{ image_width }} /  {{ number_of_columns }}),
                      (min-width: 990px) calc((100vw - {{ grid_space_desktop }}) * {{ image_width }} / {{ number_of_columns }}),
                      (min-width: 750px) calc((100vw - {{ grid_space_tablet }}) * {{ image_width }} / {{ number_of_columns_mobile }}),
                      calc((100vw - {{ grid_space_mobile }}) * {{ image_width }} / {{ number_of_columns_mobile }})
                    {% endcapture %}
                    {{
                      block.settings.image
                      | image_url: width: 3200
                      | image_tag:
                        widths: '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000, 2250, 2500, 2750, 3000, 3200',
                        sizes: sizes,
                        class: 'multicolumn-card__image'
                    }}
                  </div>
                </div>
                  </a>
              {% else %}
            	 {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="multicolumn-card__info">
                {%- if block.settings.title != blank -%}
                  <h3 class="inline-richtext">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a
                    class="link animate-arrow"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                    {{- block.settings.link_label | escape -}}
                    {% comment %}<span class="icon-wrap">&nbsp;{% render 'icon-arrow' %}</span>{% endcomment %}</a
                  >
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
   
      {% if section.settings.enable_autoplay == false and section.settings.enable_slider == true %}
        <div class="swiper-arrow swiper-button-next button-next-{{ section.id }}"></div>
        <div class="swiper-arrow swiper-button-prev button-prev-{{ section.id }}"></div>
      {% endif %}
  </div>
</div>

{% if section.settings.enable_slider == true %}
  <script type="text/javascript" defer>
    $(function() {
      window.SpeedoFashoraTheme.waitForSwiper(function() {
        requestAnimationFrame(function() {
          var SwiperTop = new Swiper('#Slider-{{ section.id }}', {
            slidesPerView: {{ section.settings.columns_desktop }},
            spaceBetween: 40,
            centeredSlides: true,
            slideToClickedSlide: true,
            speed: 2000,
            {% if section.settings.enable_autoplay == true %}
              autoplay: {
                delay: 1,
              },
            {% endif %}
            loop: true,
            slidesPerView:'auto',
            disableOnInteraction: true,
            navigation: {
              nextEl: ".button-next-{{ section.id }}",
              prevEl: ".button-prev-{{ section.id }}",
            },
            breakpoints: {
              1300: {
                slidesPerView: {{ section.settings.columns_desktop }},
                spaceBetween: 30
              },
              1200: {
                slidesPerView: {{ section.settings.columns_desktop }}-3,
                spaceBetween: 30
              },
              1025: {
                slidesPerView: {{ section.settings.columns_desktop }}-4,
                spaceBetween: 30
              },
              850: {
                slidesPerView: {{ section.settings.columns_desktop }}-5,
                spaceBetween: 30
              },
              750: {
                slidesPerView: {{ section.settings.columns_desktop }}-6,
                spaceBetween: 20
              },
              580: {
                slidesPerView: {{ section.settings.columns_desktop }}-7,
                spaceBetween: 20
              },
              480: {
                slidesPerView: {{ section.settings.columns_desktop }}-7,
                spaceBetween: 20
              },
              350: {
                slidesPerView: {{ section.settings.columns_mobile }},
                spaceBetween: 20
              },
              200: {
                slidesPerView: {{ section.settings.columns_mobile }},
                spaceBetween: 20
              }
            }
          });
    
          {% if section.settings.enable_autoplay == true %}
            $('.swiper-slide').hover(function(){
              SwiperTop.autoplay.stop();
            }, function(){
              SwiperTop.autoplay.start();
            });
          {% endif %}
        });
      });
    });
  </script>
{% endif %} 

{% schema %}
{
  "name": "t:sections.categories_slider.name",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_bleed",
          "label": "t:sections.all.layout.options__1.label"
        },
        {
          "value": "grid",			  
          "label": "t:sections.all.layout.options__2.label"
        }
      ],
      "default": "grid",
      "label": "t:sections.all.layout.label"
    },
    {
      "type": "select",
      "id": "section_view",
      "options": [
        {
          "value": "desktop",
          "label": "Show section in desktop only"
        },
        {
          "value": "mobile",			  
          "label": "Show section in mobile only"
        },
        {
          "value": "desktop_mobile",			  
          "label": "Show section in desktop and mobile"
        }
      ],
      "default": "desktop",
      "label": "Select the option to which device you want to show section"
    },
    {
      "type": "text",
      "id": "class",
      "label": "t:sections.categories_slider.settings.class.label",
      "info": "t:sections.categories_slider.settings.class.info"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Multicolumn",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.collapsible_content.settings.heading_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_width",
      "options": [
        {
          "value": "third",
          "label": "t:sections.multicolumn.settings.image_width.options__1.label"
        },
        {
          "value": "half",
          "label": "t:sections.multicolumn.settings.image_width.options__2.label"
        },
        {
          "value": "full",
          "label": "t:sections.multicolumn.settings.image_width.options__3.label"
        },
        {
          "value": "custom",
          "label": "t:sections.multicolumn.settings.image_width.options__4.label"
        }
      ],
      "default": "full",
      "label": "t:sections.multicolumn.settings.image_width.label"
    },
    {
      "type": "range",
      "id": "custom_width",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "t:sections.multicolumn.settings.custom_width.label",
      "info": "t:sections.multicolumn.settings.custom_width.info",
      "default": 70
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.multicolumn.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.multicolumn.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.multicolumn.settings.image_ratio.options__3.label"
        },
        {
          "value": "circle",
          "label": "t:sections.multicolumn.settings.image_ratio.options__4.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.multicolumn.settings.image_ratio.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 15,
      "step": 1,
      "default": 6,
      "label": "t:sections.multicolumn.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "default": true,
      "label": "t:sections.categories_slider.settings.enable_slider.label"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "t:sections.categories_slider.settings.enable_autoplay.label",
      "default": false
    },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.multicolumn.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.multicolumn.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.multicolumn.settings.column_alignment.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.multicolumn.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.multicolumn.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.multicolumn.settings.background_style.label"
    },
    {
      "type": "color",
      "id": "column_bkg_color",
      "label": "t:sections.multicolumn.settings.column_bkg_color.label",
      "default": "#F9F9F9"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "image_bkg_color",
      "label": "t:sections.categories_slider.settings.image_bkg_color.label",
      "default": "#F9F9F9"
    },
    {
      "type": "color",
      "id": "image_border_color",
      "label": "t:sections.categories_slider.settings.image_border_color.label",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "%",
      "label": "t:sections.categories_slider.settings.image_border_radius.label",
      "default": 100
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.multicolumn.settings.columns_mobile.options__2.label"
        },
        {
          "value": "3",
          "label": "3 column"
        },
        {
          "value": "4",
          "label": "4 column"
        }
      ],
      "default": "1",
      "label": "t:sections.multicolumn.settings.columns_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.multicolumn.blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.multicolumn.blocks.column.settings.image.label"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "Column",
          "label": "t:sections.multicolumn.blocks.column.settings.title.label"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
          "label": "t:sections.multicolumn.blocks.column.settings.text.label"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "t:sections.multicolumn.blocks.column.settings.link_label.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.multicolumn.blocks.column.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.categories_slider.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
