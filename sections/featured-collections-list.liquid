{{ 'section-featured-collections-list.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .section-{{ section.id }}-padding.featured-collections-list-container {
    background-color: {{ section.settings.bg_color }};
  }
  .section-{{ section.id }}-padding .featured-collections-list-item-link:hover {
    Background-color: {{ section.settings.collection_item_hover_color }};
  }
  .section-{{ section.id }}-padding .featured-collections-list-item-link {
    border-top: 1px solid {{ section.settings.border_color }};
  }
  .section-{{ section.id }}-padding li:last-child .featured-collections-list-item-link {
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .section-{{ section.id }}-padding .featured-collections-list-number {
    -webkit-text-stroke: 1px {{ section.settings.text_color }};
    color: {{ section.settings.collection_item_hover_text_color }};
  }
  .section-{{ section.id }}-padding .featured-collections-list-item-link:hover .featured-collections-list-item-title {
    color: {{ section.settings.collection_item_hover_text_color }};
  }
  .section-{{ section.id }}-padding .featured-collections-list-item-link:hover .featured-collections-list-icon {
    color: {{ section.settings.collection_item_hover_text_color }};
  }
{%- endstyle -%}

<div class="featured-collections-list-container section-{{ section.id }}-padding">
  <div class="{% if section.settings.layout == 'grid' %}page-width{% else %}full-width{% endif %}">

    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="featured-collections-list-header">
        {%- if section.settings.title != blank -%}
          <h2 class="featured-collections-list-title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="featured-collections-list-description">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="featured-collections-list-list">
      {%- for block in section.blocks -%}
        {% assign collection = block.settings.collection %}
        {% assign hover_image = block.settings.hover_image | default: collection.image %}
        
        <li>
          <a href="{{ collection.url | default: '#' }}" class="featured-collections-list-item-link" {{ block.shopify_attributes }}>
            <div class="featured-collections-list-content-wrapper">
              <span class="featured-collections-list-number">
                {%- if forloop.index < 10 -%}0{%- endif -%}{{ forloop.index }}
              </span>
              <span class="featured-collections-list-item-title">
                {%- if block.settings.title_override != blank -%}
                  {{ block.settings.title_override }}
                {%- elsif collection != blank -%}
                  {{ collection.title }}
                {%- else -%}
                  Collection Name
                {%- endif -%}
              </span>
            </div>

            <svg class="featured-collections-list-icon" width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M23.75 6.78125V20.8438C23.6719 21.7031 23.2031 22.1719 22.3438 22.25C21.4844 22.1719 21.0156 21.7031 20.9375 20.8438V10.1797L7.40234 23.7148C7.12891 23.9883 6.79688 24.125 6.40625 24.125C6.01562 24.125 5.68359 23.9883 5.41016 23.7148C4.86328 23.0508 4.86328 22.3867 5.41016 21.7227L18.9453 8.1875H8.28125C7.42188 8.10938 6.95312 7.64063 6.875 6.78125C6.95312 5.92187 7.42188 5.45312 8.28125 5.375H22.3438C23.2031 5.45312 23.6719 5.92187 23.75 6.78125Z" fill="currentColor"/>
            </svg>

            {%- if hover_image != blank -%}
              <div class="featured-collections-list-hover-image-wrapper">
                <img
                  src="{{ hover_image | image_url: width: 600 }}"
                  alt="{{ hover_image.alt | escape }}"
                  loading="lazy"
                  width="300"
                  height="{{ 300 | divided_by: hover_image.aspect_ratio | ceil }}"
                  class="featured-collections-list-hover-image"
                >
              </div>
            {%- endif -%}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured-collections-list.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_bleed",
          "label": "t:sections.featured-collections-list.settings.layout.options__1.label"
        },
        {
          "value": "grid",
          "label": "t:sections.featured-collections-list.settings.layout.options__2.label"
        }
      ],
      "default": "full_bleed",
      "label": "t:sections.featured-collections-list.settings.layout.label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "t:sections.featured-collections-list.settings.title.default",
      "label": "t:sections.featured-collections-list.settings.title.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "t:sections.featured-collections-list.settings.description.default",
      "label": "t:sections.featured-collections-list.settings.description.label"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collections-list.settings.header-color.label"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.featured-collections-list.settings.bg_color.label",
      "default": "#EDEDED"
    },
    {
      "type": "color",
      "id": "collection_item_hover_color",
      "label": "t:sections.featured-collections-list.settings.collection_item_hover_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "collection_item_hover_text_color",
      "label": "t:sections.featured-collections-list.settings.collection_item_hover_text_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.featured-collections-list.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:sections.featured-collections-list.settings.border_color.label",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "t:sections.featured-collections-list.blocks.column.settings.hover_image.label",
          "info": "t:sections.featured-collections-list.blocks.column.settings.hover_image.info"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "t:sections.featured-collections-list.blocks.column.settings.title_override.label",
          "info": "t:sections.featured-collections-list.blocks.column.settings.title_override.info"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collections-list.presets.name",
      "blocks": [
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        },
        {
          "type": "collection_item"
        }
      ]
    }
  ]
}
{% endschema %}