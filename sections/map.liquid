{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.50 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.50 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .main-map .map {
    display: flex;
    justify-content: center;
    border: 0;
  }
  @media only screen and (max-width: 749px) {
    .main-map .map iframe {
      max-height: 400px;
    }
  }
{%- endstyle -%}
<div class="main-map">
  <div class="{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    {%- if section.settings.iframe_code != blank -%}
      <div class="map" style="width: 100%;">
        <iframe
          src="{{ section.settings.iframe_code }}"
          width="100%"
          height="580"
          frameborder="0"
          style="border:0;"
        ></iframe>
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Map",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "liquid",
      "id": "iframe_code",
      "default": "https://www.google.com/maps/embed?pb=!1m16!1m12!1m3!1d2965.0824050173574!2d-93.63905729999999!3d41.998507000000004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!2m1!1sWebFilings%2C+University+Boulevard%2C+Ames%2C+IA!5e0!3m2!1sen!2sus!4v1390839289319",
      "label": "Iframe code"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.rich-text.settings.full_width.label"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Map"
    }
  ]
}
{% endschema %}
