{% if mega_title != blank or mega_image != blank %}
  <li>
    <a class="mega-collection-link" href="{{mega_itemurl}}" aria-label="{{ mega_title | escape }}">
      <div class="dropdown_mega_image_with_text">
        {%- if mega_image != blank -%}
          <div class="image_wepper">
              <div class="media media--adapt" style="padding-bottom: {{ 1 | divided_by: mega_image.aspect_ratio | times: 100}}%;">
          
            
              {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
              {%- capture sizes -%}
              (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
              (min-width: 750px) 100vw, 100vw
            {%- endcapture -%}
              {{
                mega_image
                | image_url: width: 165
                | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority, class: 'custom-icon-card__image'
              }}
                
              
              </div>
          </div>
        {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        <div class="detail">
          <h5 class="mega_title">{{mega_title}}</h5>
          <p class="mega_sub-title">{{mega_subtitle}}</p>
        </div>
      </div>
    </a>
  </li>
{% endif %}
