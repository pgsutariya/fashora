{% comment %}
  // Create a new snippet called `discount-code.liquid` and paste the provided code into this snippet.
  // After you create the file, you need to add the snippet by including the code `{% render 'discount-code' %}` in the `sections/main-cart-footer.liquid` file, right after the `<div class="totals"></div>` tag.
{% endcomment %}

{{ 'discount-code.css' | asset_url | stylesheet_tag }}

{% comment %}
